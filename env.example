# Environment variables for local development
# Copy this to .env and update the values

# Application settings
APP_NAME=Python K8s App
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database settings
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mydb
DATABASE_USER=user
DATABASE_PASSWORD=password

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-key

# AWS settings (for production)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# EKS settings
EKS_CLUSTER_NAME=python-k8s-app-eks
EKS_NAMESPACE=python-k8s-app

# ECR settings
ECR_REPOSITORY=python-k8s-app
ECR_REGISTRY=your-account-id.dkr.ecr.us-west-2.amazonaws.com
